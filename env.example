# Copy this file to .env and add your API key

# Google Gemini API Key
# Get one for free at: https://makersuite.google.com/app/apikey
GEMINI_KEY=your_api_key_here
GROQ_KEY=your_api_key_here
OPENROUTER_KEY=your_api_key_here
# Langfuse (LLM observability — leave unset to disable)
# Self-hosted: docker compose -f docker-compose.langfuse.yml up -d
# Cloud: https://cloud.langfuse.com (EU) or https://us.cloud.langfuse.com (US)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000   # or https://us.cloud.langfuse.com / https://cloud.langfuse.com
