{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "schedule": ["at any time"],
    "automerge": false,
    "prPriority": 10
  },
  "osvVulnerabilityAlerts": true,
  "timezone": "America/New_York",
  "schedule": ["after 5pm on Friday"],
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "packageRules": [
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "description": "Group npm production dependency updates",
      "matchManagers": ["bun"],
      "matchDepTypes": ["dependencies"],
      "groupName": "bun-production-deps"
    },
    {
      "description": "Group npm dev dependency updates",
      "matchManagers": ["bun"],
      "matchDepTypes": ["devDependencies"],
      "groupName": "bun-dev-deps"
    },
    {
      "description": "Group Python production dependency updates",
      "matchManagers": ["uv"],
      "matchDepTypes": ["dependencies"],
      "groupName": "uv-production-deps"
    },
    {
      "description": "Group Python dev dependency updates",
      "matchManagers": ["uv"],
      "matchDepTypes": ["dev"],
      "groupName": "uv-dev-deps"
    },
    {
      "description": "Group Python test dependency updates",
      "matchManagers": ["uv"],
      "matchDepTypes": ["tests"],
      "groupName": "uv-test-deps"
    },
    {
      "description": "Group optional dependency updates with production",
      "matchManagers": ["uv"],
      "matchDepTypes": ["tabular"],
      "groupName": "uv-production-deps"
    },
    {
      "description": "Require Python 3.10+ compatibility",
      "matchManagers": ["uv"],
      "constraintsFiltering": "strict"
    }
  ]
}
